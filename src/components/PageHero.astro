---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Icon from "./Icon.astro";

interface Crumb { label: string; href?: string }
interface Props {
  title: string;
  lede?: string;
  kicker?: string;
  image: ImageMetadata;
  imageAlt?: string;
  crumbs?: Crumb[];
  focus?: string; /* object-position */
}
const { title, lede, kicker, image, imageAlt = "", crumbs = [], focus = "center 42%" } = Astro.props;
---
<section class="phero on-dark">
  <div class="phero__media" data-parallax data-speed="0.08">
    <Image src={image} alt={imageAlt} class="phero__img" style={`object-position:${focus}`} widths={[760, 1200, 1900]} sizes="100vw" loading="eager" fetchpriority="high" />
  </div>
  <div class="phero__scrim" aria-hidden="true"></div>
  <div class="container phero__inner">
    {crumbs.length > 0 && (
      <nav class="crumbs" aria-label="Brotkrümel">
        <a href="/">Start</a>
        {crumbs.map((c) => (
          <>
            <Icon name="chevron-right" size={13} class="crumbs__sep" />
            {c.href ? <a href={c.href}>{c.label}</a> : <span aria-current="page">{c.label}</span>}
          </>
        ))}
      </nav>
    )}
    {kicker && <p class="kicker phero__kicker">{kicker}</p>}
    <h1 class="phero__title">{title}</h1>
    {lede && <p class="lede phero__lede">{lede}</p>}
  </div>
  <div class="phero__fade" aria-hidden="true"></div>
</section>

<style>
  .phero {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: clamp(380px, 56vh, 560px);
    padding-top: 8rem;
    padding-bottom: clamp(2.6rem, 1.5rem + 4vw, 4.5rem);
    overflow: clip;
    isolation: isolate;
  }
  .phero__media { position: absolute; inset: -12% 0; z-index: -2; }
  .phero__img { width: 100%; height: 100%; object-fit: cover; transform: translateY(var(--py, 0)); }
  .phero__scrim {
    position: absolute; inset: 0; z-index: -1;
    background:
      linear-gradient(to top, oklch(0.17 0.022 158 / 0.92) 4%, oklch(0.19 0.025 158 / 0.45) 42%, oklch(0.2 0.03 160 / 0.15) 75%),
      linear-gradient(105deg, oklch(0.18 0.025 160 / 0.55), transparent 60%);
  }
  .phero__fade {
    position: absolute; inset: auto 0 0 0; height: 90px; z-index: -1;
    background: linear-gradient(to bottom, transparent, var(--paper));
  }
  .phero__inner { position: relative; }
  .crumbs { display: flex; align-items: center; gap: 0.35rem; flex-wrap: wrap; margin-bottom: 1.3rem; }
  .crumbs a, .crumbs span { font-size: 0.84rem; font-weight: 500; color: oklch(0.92 0.01 165 / 0.8); }
  .crumbs a { transition: color 0.2s; }
  .crumbs a:hover { color: var(--brass-400); }
  .crumbs span { color: var(--brass-400); }
  .crumbs__sep { color: oklch(1 0 0 / 0.4); }
  .phero__kicker { color: var(--brass-400); margin-bottom: 0.9rem; }
  .phero__kicker::before { background: var(--brass-400); }
  .phero__title {
    font-size: var(--step-5);
    font-weight: 420;
    line-height: 0.98;
    letter-spacing: -0.022em;
    color: var(--white);
    max-width: 18ch;
  }
  .phero__lede { color: oklch(0.94 0.01 165 / 0.92); margin-top: 1.3rem; max-width: 56ch; }
</style>
