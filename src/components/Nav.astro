---
import { nav, site } from "../data/site";
import Burgee from "./Burgee.astro";
import Icon from "./Icon.astro";

const path = Astro.url.pathname.replace(/\/+$/, "") + "/";
const isActive = (href: string) => {
  const h = href.replace(/\/+$/, "") + "/";
  if (h === "/") return path === "/";
  return path === h || path.startsWith(h);
};
const centerItems = nav.filter((n) => n.label !== "Mitglieder");
const memberItem = nav.find((n) => n.label === "Mitglieder")!;
---
<header class="masthead" id="masthead" data-nav>
  <div class="masthead__inner">
    <a href="/" class="brand" aria-label={`${site.name} – Startseite`}>
      <Burgee size={34} />
      <span class="brand__text">
        <span class="brand__name">YCaT</span>
        <span class="brand__sub">Yacht-Club am Tegernsee</span>
      </span>
    </a>

    <nav class="nav-desktop" aria-label="Hauptnavigation">
      <ul class="nav-list">
        {centerItems.map((item) => (
          <li class={`nav-item ${item.children ? "has-menu" : ""}`}>
            {item.children ? (
              <>
                <a href={item.href} class={`nav-link ${isActive(item.href) ? "is-active" : ""}`} aria-haspopup="true">
                  {item.label}
                  <Icon name="chevron-down" size={15} class="nav-caret" />
                </a>
                <div class="dropdown" role="menu">
                  <div class="dropdown__card">
                    {item.children.map((c) => (
                      <a href={c.href} class={`dropdown__link ${isActive(c.href) && c.href !== item.href ? "is-active" : ""}`}
                        role="menuitem" {...(c.external ? { target: "_blank", rel: "noopener" } : {})}>
                        <span class="dropdown__label">{c.label}</span>
                        {c.note && <span class="dropdown__note">{c.note}</span>}
                        {c.external && <Icon name="arrow-up-right" size={14} class="dropdown__ext" />}
                      </a>
                    ))}
                  </div>
                </div>
              </>
            ) : (
              <a href={item.href} class={`nav-link ${isActive(item.href) ? "is-active" : ""}`}>{item.label}</a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="masthead__actions">
      <a href={memberItem.href} class={`member-btn ${isActive(memberItem.href) ? "is-active" : ""}`}>
        <Icon name="lock" size={16} />
        <span>Mitglieder</span>
      </a>
      <button class="nav-toggle" id="navToggle" aria-label="Menü öffnen" aria-expanded="false" aria-controls="navOverlay">
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile overlay -->
<div class="nav-overlay" id="navOverlay" hidden>
  <div class="nav-overlay__scrim"></div>
  <nav class="nav-overlay__panel" aria-label="Mobile Navigation">
    <div class="nav-overlay__inner">
      {nav.map((item, i) => (
        <div class="m-group" style={`--i:${i}`}>
          <a href={item.href} class={`m-link ${isActive(item.href) ? "is-active" : ""}`}>{item.label}</a>
          {item.children && (
            <div class="m-sub">
              {item.children.map((c) => (
                <a href={c.href} class="m-sublink" {...(c.external ? { target: "_blank", rel: "noopener" } : {})}>
                  {c.label}{c.note ? <em> · {c.note}</em> : null}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <div class="m-foot" style={`--i:${nav.length}`}>
        <a href={`tel:${site.phone.replace(/[^+\d]/g, "")}`} class="m-foot__item"><Icon name="phone" size={17} />{site.phone}</a>
        <a href={`mailto:${site.email}`} class="m-foot__item"><Icon name="mail" size={17} />{site.email}</a>
      </div>
    </div>
  </nav>
</div>

<style>
  .masthead {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: var(--z-nav);
    padding: clamp(0.6rem, 0.3rem + 1vw, 1.1rem) var(--gutter);
    display: flex;
    justify-content: center;
    pointer-events: none;
  }
  .masthead__inner {
    pointer-events: auto;
    width: 100%;
    max-width: var(--container-wide);
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 0.5rem 0.6rem 0.5rem 1.1rem;
    border-radius: 999px;
    background: oklch(0.99 0.004 160 / 0.72);
    border: 1px solid oklch(0.5 0.04 160 / 0.1);
    box-shadow: 0 1px 0 oklch(1 0 0 / 0.6) inset, var(--shadow-sm);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    transition: max-width 0.7s var(--ease-expo), background-color 0.4s var(--ease-quart),
      box-shadow 0.5s var(--ease-expo), padding 0.5s var(--ease-expo);
  }
  .masthead.is-scrolled .masthead__inner {
    max-width: var(--container);
    background: oklch(0.99 0.004 160 / 0.88);
    box-shadow: 0 1px 0 oklch(1 0 0 / 0.6) inset, var(--shadow-md);
  }

  .brand { display: inline-flex; align-items: center; gap: 0.7rem; flex-shrink: 0; }
  .brand__text { display: flex; flex-direction: column; line-height: 1; }
  .brand__name {
    font-family: var(--font-display);
    font-size: 1.32rem;
    font-weight: 540;
    letter-spacing: -0.01em;
    color: var(--pine-900);
  }
  .brand__sub {
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-top: 2px;
  }

  .nav-desktop { margin-inline: auto; }
  .nav-list { display: flex; align-items: center; gap: 0.15rem; list-style: none; padding: 0; }
  .nav-item { position: relative; }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    font-size: 0.93rem;
    font-weight: 540;
    letter-spacing: -0.006em;
    color: var(--ink-soft);
    white-space: nowrap;
    transition: color 0.2s, background-color 0.25s var(--ease-quart);
  }
  .nav-caret { opacity: 0.5; transition: transform 0.35s var(--ease-expo); margin-left: -1px; }
  .nav-link:hover { color: var(--pine-900); background: oklch(0.5 0.04 160 / 0.07); }
  .nav-link.is-active { color: var(--pine-800); }
  .nav-link.is-active::after {
    content: ""; position: absolute; left: 50%; bottom: 1px; translate: -50% 0;
    width: 5px; height: 5px; border-radius: 50%; background: var(--brass-500);
  }
  .has-menu:hover .nav-caret, .has-menu:focus-within .nav-caret { transform: rotate(180deg); }

  .dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    translate: -50% 0;
    min-width: 250px;
    padding-top: 0.4rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.3s var(--ease-quart), transform 0.4s var(--ease-expo), visibility 0.3s;
    z-index: var(--z-nav);
  }
  .has-menu:hover .dropdown, .has-menu:focus-within .dropdown {
    opacity: 1; visibility: visible; transform: translateY(0);
  }
  .dropdown__card {
    background: oklch(0.99 0.004 160 / 0.96);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
  }
  .dropdown__link {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.62rem 0.8rem;
    border-radius: 11px;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink-soft);
    transition: background-color 0.2s, color 0.2s;
  }
  .dropdown__link:hover { background: var(--surface-2); color: var(--pine-900); }
  .dropdown__link.is-active { color: var(--pine-800); background: oklch(0.66 0.082 200 / 0.1); }
  .dropdown__label { flex: 1; }
  .dropdown__note {
    font-size: 0.68rem; font-weight: 600; letter-spacing: 0.02em;
    color: var(--muted); background: var(--surface-2);
    padding: 0.12rem 0.45rem; border-radius: 6px;
  }
  .dropdown__ext { color: var(--muted); }

  .masthead__actions { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
  .member-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.62rem 1.1rem;
    border-radius: 999px;
    background: var(--pine-800);
    color: var(--white);
    font-size: 0.9rem; font-weight: 600;
    transition: transform 0.4s var(--ease-expo), background-color 0.3s;
  }
  .member-btn:hover { transform: translateY(-1px); background: var(--pine-900); }
  .member-btn svg { opacity: 0.8; }

  .nav-toggle {
    display: none;
    width: 44px; height: 44px;
    border-radius: 999px;
    background: var(--pine-800);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
  }
  .nav-toggle__bar {
    width: 18px; height: 1.8px; border-radius: 2px; background: var(--white);
    transition: transform 0.4s var(--ease-expo), opacity 0.3s;
  }
  body.nav-open .nav-toggle__bar:nth-child(1) { transform: translateY(3.4px) rotate(45deg); }
  body.nav-open .nav-toggle__bar:nth-child(2) { transform: translateY(-3.4px) rotate(-45deg); }

  /* ---------- Mobile overlay ---------- */
  .nav-overlay { position: fixed; inset: 0; z-index: calc(var(--z-nav) - 1); }
  .nav-overlay[hidden] { display: none; }
  .nav-overlay__scrim {
    position: absolute; inset: 0;
    background: oklch(0.17 0.022 158 / 0.4);
    opacity: 0; transition: opacity 0.5s var(--ease-quart);
    backdrop-filter: blur(4px);
  }
  .nav-overlay__panel {
    position: absolute; inset: 0;
    background:
      radial-gradient(120% 80% at 90% 0%, oklch(0.36 0.06 185 / 0.5), transparent 60%),
      var(--pine-950);
    transform: translateY(-100%);
    transition: transform 0.6s var(--ease-expo);
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  body.nav-open .nav-overlay__scrim { opacity: 1; }
  body.nav-open .nav-overlay__panel { transform: translateY(0); }
  .nav-overlay__inner {
    min-height: 100%;
    padding: clamp(5.5rem, 16vw, 8rem) var(--gutter) 3rem;
    display: flex; flex-direction: column;
    max-width: 560px; margin-inline: auto;
  }
  .m-group {
    padding: 1rem 0;
    border-bottom: 1px solid oklch(1 0 0 / 0.08);
    opacity: 0; transform: translateY(18px);
  }
  body.nav-open .m-group {
    animation: mIn 0.6s var(--ease-expo) forwards;
    animation-delay: calc(0.12s + var(--i) * 0.05s);
  }
  @keyframes mIn { to { opacity: 1; transform: none; } }
  .m-link {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 7vw, 2.3rem);
    font-weight: 440;
    letter-spacing: -0.02em;
    color: var(--white);
  }
  .m-link.is-active { color: var(--brass-400); }
  .m-sub { display: flex; flex-wrap: wrap; gap: 0.4rem 1.1rem; margin-top: 0.7rem; }
  .m-sublink { font-size: 0.95rem; color: var(--on-dark-muted); font-weight: 500; }
  .m-sublink em { color: var(--brass-400); font-style: normal; }
  .m-sublink:hover { color: var(--white); }
  .m-foot {
    margin-top: auto; padding-top: 2rem;
    display: flex; flex-direction: column; gap: 0.9rem;
    opacity: 0; transform: translateY(18px);
  }
  body.nav-open .m-foot { animation: mIn 0.6s var(--ease-expo) forwards; animation-delay: calc(0.12s + var(--i) * 0.05s); }
  .m-foot__item { display: inline-flex; align-items: center; gap: 0.6rem; color: var(--on-dark-muted); font-weight: 500; }
  .m-foot__item svg { color: var(--brass-400); }

  @media (max-width: 1080px) {
    .nav-desktop, .member-btn { display: none; }
    .nav-toggle { display: flex; }
    .masthead__actions { margin-left: auto; }
  }
  @media (max-width: 460px) {
    .brand__sub { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-overlay__panel { transition: none; }
    body.nav-open .m-group, body.nav-open .m-foot { animation: none; opacity: 1; transform: none; }
  }
</style>

<script>
  const toggle = document.getElementById("navToggle");
  const overlay = document.getElementById("navOverlay");
  const masthead = document.getElementById("masthead");

  function setOpen(open: boolean) {
    document.body.classList.toggle("nav-open", open);
    toggle?.setAttribute("aria-expanded", String(open));
    toggle?.setAttribute("aria-label", open ? "Menü schließen" : "Menü öffnen");
    if (open) {
      overlay?.removeAttribute("hidden");
      (window as any).lenis?.stop?.();
    } else {
      (window as any).lenis?.start?.();
      setTimeout(() => { if (!document.body.classList.contains("nav-open")) overlay?.setAttribute("hidden", ""); }, 600);
    }
  }
  toggle?.addEventListener("click", () => setOpen(!document.body.classList.contains("nav-open")));
  overlay?.querySelector(".nav-overlay__scrim")?.addEventListener("click", () => setOpen(false));
  overlay?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") setOpen(false); });

  // Scrolled state – lightweight rAF-guarded class toggle.
  let ticking = false;
  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      masthead?.classList.toggle("is-scrolled", window.scrollY > 24);
      ticking = false;
    });
  }
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
