---
import "../styles/global.css";
import Nav from "./Nav.astro";
import Footer from "./Footer.astro";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title,
  description = "Yacht-Club am Tegernsee e.V. – Segelsport, Jugendförderung, Regatten und Liegeplätze am schönsten Voralpensee. Faszination Segelsport ein Leben lang, seit 1931.",
  ogImage = "/og-default.jpg",
} = Astro.props;

const fullTitle = title ? `${title} – YCaT` : `${site.name} – ${site.tagline}`;
const origin = (Astro.site ?? new URL("https://www.ycat.de")).origin;
const base = import.meta.env.BASE_URL; // "/" locally, "/YCAT" on GitHub Pages
const canonical = origin + Astro.url.pathname;
const ogImageUrl = origin + `/${base}/${ogImage}`.replace(/\/+/g, "/");
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#1d3b30" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,340..620;1,9..144,360..520&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <div class="grain" aria-hidden="true"></div>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      import Lenis from "lenis";

      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // Smooth inertia scroll (cinematic), disabled for reduced motion.
      if (!reduce) {
        const lenis = new Lenis({ duration: 1.05, smoothWheel: true, lerp: 0.1 });
        (window as any).lenis = lenis;
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // In-page anchor links go through Lenis.
        document.querySelectorAll('a[href^="#"]').forEach((a) => {
          a.addEventListener("click", (e) => {
            const id = a.getAttribute("href");
            if (!id || id === "#") return;
            const el = document.querySelector(id);
            if (el) { e.preventDefault(); lenis.scrollTo(el as HTMLElement, { offset: -90 }); }
          });
        });
      }

      // Scroll reveal – enhances an already-visible default.
      const items = document.querySelectorAll("[data-reveal]");
      if ("IntersectionObserver" in window && !reduce) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.12 }
        );
        items.forEach((el) => io.observe(el));
        // Backstop: guarantee everything shows even if observer never fires.
        window.addEventListener("load", () =>
          setTimeout(() => items.forEach((el) => el.classList.add("is-visible")), 1400)
        );
      } else {
        items.forEach((el) => el.classList.add("is-visible"));
      }

      // Parallax for [data-parallax] (speed via data-speed), rAF-guarded.
      const px = Array.from(document.querySelectorAll<HTMLElement>("[data-parallax]"));
      if (px.length && !reduce) {
        let tick = false;
        const run = () => {
          const vh = window.innerHeight;
          px.forEach((el) => {
            const r = el.getBoundingClientRect();
            const speed = parseFloat(el.dataset.speed || "0.12");
            const offset = (r.top + r.height / 2 - vh / 2) * -speed;
            el.style.setProperty("--py", `${offset.toFixed(1)}px`);
          });
          tick = false;
        };
        const onScroll = () => { if (!tick) { tick = true; requestAnimationFrame(run); } };
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", onScroll);
        run();
      }
    </script>
  </body>
</html>
