---
import Layout from "../components/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHead from "../components/SectionHead.astro";
import Reveal from "../components/Reveal.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";
import lakePanorama from "../assets/photos/lake-panorama.jpg";

const routes = [
  {
    dir: "Von Norden",
    text: "Sie fahren die Autobahn A8 München–Salzburg bis zur Ausfahrt Holzkirchen und dann die B318/B307 in das Tegernseer Tal. In Tegernsee fahren Sie am Schloss vorbei und gelangen an dessen südlichem Ende direkt zum Gelände des YCaT auf der rechten Straßenseite. Der Club ist im gelben Hoffischereigebäude untergebracht, auf das Sie unweigerlich zufahren.",
  },
  {
    dir: "Von Süden",
    text: "Entweder über das Inntal, den Achenpass und die B307 oder über die Inntalautobahn und die A8 München–Salzburg bis zur Ausfahrt Irschenberg. In Tegernsee überqueren Sie den Leeberg und fahren anschließend ca. 300 m weiter am Clubgelände entlang. Die Einfahrt befindet sich auf der linken Straßenseite, am Ende des gelben Hoffischereigebäudes.",
  },
];
const telHref = `tel:${site.phone.replace(/[^+\d]/g, "")}`;
---
<Layout title="Kontakt & Anfahrt" description="Kontakt und Anfahrt zum Yacht-Club am Tegernsee – Seestraße 42, 83684 Tegernsee. Telefon, E-Mail und Wegbeschreibung von Norden und Süden.">
  <PageHero
    image={lakePanorama}
    imageAlt="Blick über den Tegernsee"
    kicker="Hallo am See"
    title="Kontakt & Anfahrt"
    lede="Im gelben Hoffischereigebäude direkt am Wasser – wir freuen uns auf euren Besuch."
    crumbs={[{ label: "Kontakt" }]}
  />

  <section class="section">
    <div class="container contact">
      <Reveal class="contact__card">
        <p class="kicker">Geschäftsstelle</p>
        <h2 class="contact__name">Yacht-Club am Tegernsee e.V.</h2>
        <ul class="contact__list">
          <li><Icon name="pin" size={18} /><span>{site.address.street}<br />{site.address.zip} {site.address.city}</span></li>
          <li><Icon name="phone" size={18} /><a href={telHref}>{site.phone}</a></li>
          <li><Icon name="external" size={18} /><span>Fax {site.fax}</span></li>
          <li><Icon name="mail" size={18} /><a href={`mailto:${site.email}`}>{site.email}</a></li>
        </ul>
        <div class="contact__actions">
          <a href={`https://www.openstreetmap.org/?mlat=47.7096&mlon=11.7585#map=17/47.7096/11.7585`} target="_blank" rel="noopener" class="btn btn--ghost">
            Route planen <span class="btn__icon"><Icon name="arrow-up-right" size={15} /></span>
          </a>
        </div>
      </Reveal>

      <Reveal class="contact__map" delay={100}>
        <iframe
          title="Karte: Yacht-Club am Tegernsee"
          loading="lazy"
          src="https://www.openstreetmap.org/export/embed.html?bbox=11.748%2C47.703%2C11.770%2C47.717&layer=mapnik&marker=47.7096%2C11.7585"
        ></iframe>
      </Reveal>
    </div>
  </section>

  <section class="section-sm bg-surface">
    <div class="container">
      <SectionHead kicker="Anfahrt" title="So findet ihr ans Clubgelände" />
      <div class="routes">
        {routes.map((r, i) => (
          <Reveal as="article" class="route" delay={i * 90}>
            <span class="route__icon"><Icon name="compass" size={22} /></span>
            <h3>{r.dir}</h3>
            <p>{r.text}</p>
          </Reveal>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: clamp(1.4rem, 0.5rem + 3vw, 2.6rem); align-items: stretch; }
  .contact__card { padding: clamp(1.6rem, 1rem + 2vw, 2.4rem); background: var(--pine-900); color: var(--on-dark); border-radius: var(--radius-lg); box-shadow: var(--shadow-md); }
  .contact__card .kicker { color: var(--brass-400); }
  .contact__card .kicker::before { background: var(--brass-400); }
  .contact__name { color: var(--white); font-size: var(--step-2); margin-top: 0.8rem; }
  .contact__list { list-style: none; padding: 0; margin-top: 1.6rem; display: flex; flex-direction: column; gap: 1rem; }
  .contact__list li { display: flex; gap: 0.8rem; align-items: flex-start; color: oklch(0.94 0.01 165 / 0.92); line-height: 1.5; }
  .contact__list svg { color: var(--brass-400); flex-shrink: 0; margin-top: 2px; }
  .contact__list a { transition: color 0.2s; }
  .contact__list a:hover { color: var(--brass-400); }
  .contact__actions { margin-top: 1.8rem; }
  .contact__map { border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--line); min-height: 360px; box-shadow: var(--shadow-sm); }
  .contact__map iframe { width: 100%; height: 100%; min-height: 360px; border: 0; display: block; filter: saturate(0.92); }

  .routes { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2.4rem; }
  .route { padding: clamp(1.5rem, 1rem + 2vw, 2.2rem); background: var(--white); border: 1px solid var(--line); border-radius: var(--radius-lg); }
  .route__icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 14px; background: var(--lake-200); color: var(--lake-700); margin-bottom: 1rem; }
  .route h3 { font-size: var(--step-1); margin-bottom: 0.6rem; }
  .route p { color: var(--ink-soft); font-size: 0.95rem; }

  @media (max-width: 880px) { .contact, .routes { grid-template-columns: 1fr; } }
</style>
