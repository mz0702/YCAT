---
import Layout from "../../components/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import Reveal from "../../components/Reveal.astro";
import Icon from "../../components/Icon.astro";
import dock from "../../assets/photos/dock.jpg";

const tasks = [
  "Südsteg & Reparaturen am Hauptsteg",
  "Mitgliedersitzplatz",
  "Maßnahmen am Rasen im Herbst",
  "Unterstützung der Regattaleiter",
  "Rasenmähen – viele Hände, schnelle Arbeit",
];
---
<Layout title="Arbeitsdienst" description="Arbeitsdienst im YCaT – wir brauchen helfende Hände für Stege, Rasen und den Regattabetrieb. Kontakt: Erik Weidinger.">
  <PageHero
    image={dock}
    imageAlt="Steg am YCaT-Hafen"
    kicker="Hafen"
    title="Arbeitsdienst"
    lede="Ein Verein lebt vom Mitmachen. Für viele Projekte rund um Hafen und Gelände brauchen wir helfende Hände – gemeinsam geht es leichter und macht mehr Spaß."
    crumbs={[{ label: "Hafen", href: "/hafen/" }, { label: "Arbeitsdienst" }]}
    focus="center 55%"
  />

  <section class="section">
    <div class="container article">
      <div class="article__main">
        <Reveal as="p" class="lede">Liebe Mitglieder,</Reveal>
        <Reveal as="p" class="prose article__p" delay={60}>
          wir brauchen viele helfende Hände für verschiedene Projekte. Daneben freuen sich unsere
          Regattaleiter über Unterstützung – und beim Rasenmähen geht es zu zweit einfach schneller.
          Jede Stunde zählt und kommt dem ganzen Club zugute.
        </Reveal>
        <Reveal as="ul" class="task-list" delay={120}>
          {tasks.map((t) => <li><Icon name="anchor" size={16} />{t}</li>)}
        </Reveal>
        <Reveal as="p" class="prose article__p" delay={160}>
          Für genauere Infos, neue Vorschläge, Termine und Abstimmung bitten wir um Kontaktaufnahme
          mit Erik Weidinger.
        </Reveal>
      </div>

      <Reveal class="article__aside" delay={100}>
        <div class="contact-card">
          <p class="kicker">Ansprechpartner</p>
          <h3>Erik Weidinger</h3>
          <p class="contact-card__role">2. Vorsitzender</p>
          <ul>
            <li><Icon name="phone" size={17} /><a href="tel:+491719936676">+49 (0)171 9936676</a></li>
            <li><Icon name="mail" size={17} /><a href="mailto:weidinger@ycat.de">weidinger@ycat.de</a></li>
          </ul>
          <a href="mailto:weidinger@ycat.de?subject=Arbeitsdienst" class="btn btn--accent contact-card__btn">
            Mithelfen <span class="btn__icon"><Icon name="arrow-right" size={16} /></span>
          </a>
        </div>
      </Reveal>
    </div>
  </section>
</Layout>

<style>
  .article { display: grid; grid-template-columns: 1.6fr 1fr; gap: clamp(1.6rem, 0.5rem + 4vw, 3.5rem); align-items: start; }
  .article__p { margin-top: 1.1rem; }
  .task-list { list-style: none; padding: 0; margin: 1.6rem 0; display: flex; flex-direction: column; gap: 0.2rem; }
  .task-list li { display: flex; align-items: center; gap: 0.7rem; padding: 0.7rem 0; border-bottom: 1px solid var(--line); color: var(--ink-soft); font-weight: 500; }
  .task-list svg { color: var(--brass-500); flex-shrink: 0; }

  .contact-card { padding: clamp(1.6rem, 1rem + 2vw, 2.2rem); background: var(--pine-900); color: var(--on-dark); border-radius: var(--radius-lg); position: sticky; top: 6.5rem; box-shadow: var(--shadow-md); }
  .contact-card .kicker { color: var(--brass-400); }
  .contact-card .kicker::before { background: var(--brass-400); }
  .contact-card h3 { color: var(--white); margin-top: 0.7rem; }
  .contact-card__role { color: var(--on-dark-muted); font-size: 0.9rem; margin-top: 0.2rem; }
  .contact-card ul { list-style: none; padding: 0; margin: 1.4rem 0; display: flex; flex-direction: column; gap: 0.8rem; }
  .contact-card li { display: flex; align-items: center; gap: 0.7rem; color: oklch(0.94 0.01 165 / 0.92); }
  .contact-card svg { color: var(--brass-400); flex-shrink: 0; }
  .contact-card a:hover { color: var(--brass-400); }
  .contact-card__btn { margin-top: 0.3rem; }

  @media (max-width: 880px) { .article { grid-template-columns: 1fr; } .contact-card { position: static; } }
</style>
