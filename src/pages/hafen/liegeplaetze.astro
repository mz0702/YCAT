---
import Layout from "../../components/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHead from "../../components/SectionHead.astro";
import Reveal from "../../components/Reveal.astro";
import Icon from "../../components/Icon.astro";
import harbour from "../../assets/photos/harbour.jpg";

const places = [
  { type: "Bojenplatz", available: 0, icon: "anchor" },
  { type: "Stegplatz", available: 0, icon: "waves" },
  { type: "Landliegeplatz Wiese", available: 0, icon: "flag" },
  { type: "Landliegeplatz Teerfläche", available: 0, icon: "compass" },
];
---
<Layout title="Liegeplätze" description="Liegeplätze am YCaT – Boje, Steg und Land für reviergeeignete Bootsklassen. Interessentenliste über die Geschäftsstelle oder den Hafenmeister.">
  <PageHero
    image={harbour}
    imageAlt="Liegeplätze und Boote am YCaT-Hafen"
    kicker="Hafen"
    title="Liegeplätze"
    lede="Mitgliedern – oder solchen, die es werden wollen – mit einer zum YCaT passenden Bootsklasse bieten wir Liegeplätze an Boje, Steg und Land."
    crumbs={[{ label: "Hafen", href: "/hafen/" }, { label: "Liegeplätze" }]}
    focus="center 60%"
  />

  <section class="section">
    <div class="container">
      <SectionHead kicker="Verfügbare Dauerplätze" title="Aktuelle Platzsituation" />
      <div class="places">
        {places.map((p, i) => (
          <Reveal as="div" class="place" delay={i * 70}>
            <span class="place__icon"><Icon name={p.icon} size={22} /></span>
            <span class="place__type">{p.type}</span>
            <span class="place__status">
              {p.available > 0
                ? <span class="place__free">{p.available} frei</span>
                : <span class="place__wait">Warteliste</span>}
            </span>
          </Reveal>
        ))}
      </div>

      <div class="lg-cols">
        <Reveal class="lg-card">
          <h3>Auf die Interessentenliste</h3>
          <p>
            Derzeit sind alle Dauerplätze belegt. Bitte wenden Sie sich an unsere Geschäftsstelle
            oder direkt an unseren Hafenmeister Volker Schütz für einen Platz auf der
            Interessentenliste – passend zu Ihrer Bootsklasse.
          </p>
          <div class="lg-card__actions">
            <a href="mailto:schuetz@ycat.de?subject=Interessentenliste%20Liegeplatz" class="btn btn--accent">
              Auf die Liste setzen <span class="btn__icon"><Icon name="arrow-right" size={16} /></span>
            </a>
            <a href="/kontakt/" class="link-arrow">Geschäftsstelle <Icon name="arrow-right" size={15} /></a>
          </div>
        </Reveal>

        <Reveal class="lg-card lg-card--guest" delay={100}>
          <span class="lg-card__icon"><Icon name="life-ring" size={22} /></span>
          <h3>Gäste</h3>
          <p>Gastliegeplätze und Konditionen entnehmen Sie bitte den Downloads bzw. erfragen Sie diese beim Hafenmeister.</p>
          <a href="mailto:schuetz@ycat.de?subject=Gastliegeplatz" class="link-arrow">Gastplatz anfragen <Icon name="arrow-right" size={15} /></a>
        </Reveal>
      </div>
    </div>
  </section>
</Layout>

<style>
  .places { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 2.4rem; }
  .place { display: flex; flex-direction: column; gap: 0.8rem; padding: 1.6rem; background: var(--white); border: 1px solid var(--line); border-radius: var(--radius-lg); }
  .place__icon { display: grid; place-items: center; width: 46px; height: 46px; border-radius: 13px; background: var(--lake-200); color: var(--lake-700); }
  .place__type { font-family: var(--font-display); font-size: 1.08rem; font-weight: 500; color: var(--pine-900); }
  .place__free { display: inline-flex; padding: 0.3rem 0.7rem; border-radius: 7px; background: oklch(0.52 0.07 154 / 0.14); color: var(--pine-700); font-weight: 600; font-size: 0.85rem; }
  .place__wait { display: inline-flex; padding: 0.3rem 0.7rem; border-radius: 7px; background: var(--brass-200); color: var(--brass-600); font-weight: 600; font-size: 0.85rem; }

  .lg-cols { display: grid; grid-template-columns: 1.5fr 1fr; gap: 1.2rem; margin-top: 1.2rem; }
  .lg-card { padding: clamp(1.6rem, 1rem + 2vw, 2.4rem); background: var(--surface); border-radius: var(--radius-lg); }
  .lg-card h3 { font-size: var(--step-2); margin-bottom: 0.7rem; }
  .lg-card p { color: var(--ink-soft); }
  .lg-card__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem 1.4rem; margin-top: 1.6rem; }
  .lg-card--guest { background: var(--pine-900); color: var(--on-dark); }
  .lg-card--guest h3 { color: var(--white); }
  .lg-card--guest p { color: oklch(0.92 0.01 165 / 0.85); }
  .lg-card--guest .link-arrow { color: var(--brass-400); margin-top: 1.2rem; }
  .lg-card__icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 14px; background: oklch(1 0 0 / 0.1); color: var(--brass-400); margin-bottom: 1rem; }

  @media (max-width: 900px) { .places { grid-template-columns: repeat(2, 1fr); } .lg-cols { grid-template-columns: 1fr; } }
  @media (max-width: 480px) { .places { grid-template-columns: 1fr; } }
</style>
