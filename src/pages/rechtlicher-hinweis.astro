---
import Layout from "../components/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Reveal from "../components/Reveal.astro";
import standard03 from "../assets/photos/standard-03.jpg";

type Section = { id: string; title: string; level: 2 | 3; body: string[] };

const sections: Section[] = [
  { id: "datenschutz", level: 2, title: "1. Datenschutzerklärung", body: [
    "Der Yacht-Club am Tegernsee e.V. (im Folgenden YCaT) nimmt als Anbieter der Website ycat.de und verantwortliche Stelle die Verpflichtung zum Datenschutz sehr ernst und gestaltet seine Website so, dass nur so wenige personenbezogene Daten wie nötig erhoben, verarbeitet und genutzt werden. Unter keinen Umständen werden personenbezogene Daten zu Werbezwecken an Dritte vermietet oder verkauft. Ohne die ausdrückliche Einwilligung des Besuchers werden keine personenbezogenen Daten für Werbe- oder Marketingzwecke genutzt.",
    "Zugriff auf personenbezogene Daten haben beim YCaT nur solche Personen, die diese Daten zur Durchführung ihrer Aufgaben benötigen und sich gemäß der geltenden gesetzlichen Bestimmungen (Art. 5 EU-DSGVO) verpflichtet haben, diese einzuhalten. Erhebung, Verarbeitung, Nutzung und Übermittlung erfolgen nach Art. 6 Abs. 1 EU-DSGVO, jeweils nur im erforderlichen Umfang.",
    "Der Nutzung unserer im Rahmen der Impressumspflicht veröffentlichten Kontaktdaten durch Dritte zur Übersendung nicht ausdrücklich angeforderter Werbung wird hiermit ausdrücklich widersprochen.",
  ]},
  { id: "zweck", level: 3, title: "1.1 Zweckänderungen der Verarbeitung", body: [
    "Da sich die eingesetzten Verarbeitungsverfahren aufgrund technischen Fortschritts und organisatorischer Änderungen weiterentwickeln können, behalten wir uns vor, diese Datenschutzerklärung entsprechend anzupassen und an dieser Stelle zu veröffentlichen. Sie können jederzeit gemäß Art. 17 EU-DSGVO eine Löschung der Daten verlangen, soweit keine gesetzlichen Aufbewahrungspflichten entgegenstehen.",
  ]},
  { id: "anonym", level: 3, title: "1.2 Anonyme Datenerhebung", body: [
    "Sie können unsere Webseiten grundsätzlich besuchen, ohne uns mitzuteilen, wer Sie sind. Wir erfahren nur den Namen Ihres Internet-Service-Providers, die Webseite, von der aus Sie uns besuchen, und die Webseiten, die Sie bei uns besuchen. Diese Informationen werden zu statistischen Zwecken ausgewertet; Sie bleiben dabei anonym.",
  ]},
  { id: "erhebung", level: 3, title: "1.3 Erhebung personenbezogener Daten", body: [
    "Personenbezogene Daten werden nur erhoben, wenn Sie uns diese von sich aus mitteilen – etwa zur Anmeldung zu einer Regatta oder zum Login in den Mitgliederbereich. Die verantwortliche Stelle hält sich an die Vorgaben der Art. 5 und 6 EU-DSGVO. Sie haben jederzeit die Möglichkeit, der Speicherung zu widersprechen – senden Sie dazu eine E-Mail an info@ycat.de.",
  ]},
  { id: "export", level: 3, title: "1.4 Verarbeitung außerhalb des EWR", body: [
    "Es findet kein Export Ihrer personenbezogenen Daten in Staaten außerhalb des Europäischen Wirtschaftsraumes (EWR) statt. Die eingeschalteten Dienstleister betreiben ihre IT-Infrastruktur ausschließlich innerhalb des EWR; mit ihnen bestehen Verträge gemäß EU-DSGVO. Sofern Sie bei Google eingeloggt sind oder einen YouTube-Account besitzen, können personenbezogene Daten in die USA exportiert werden.",
  ]},
  { id: "weitergabe", level: 3, title: "1.5 Nutzung und Weitergabe", body: [
    "Die erhobenen personenbezogenen Daten werden ohne Ihre Einwilligung nur zur Vertragsabwicklung und Bearbeitung Ihrer Anfragen genutzt. Eine Nutzung für Werbung und Marktforschung erfolgt nur mit Ihrer vorherigen Einwilligung. Im Übrigen findet keine Weitergabe an Dritte statt. Ihre Einwilligung können Sie jederzeit mit Wirkung für die Zukunft widerrufen.",
  ]},
  { id: "links", level: 3, title: "1.6 Externe Links", body: [
    "Auf unseren Seiten finden Sie Links, die auf Seiten Dritter verweisen. Die verantwortliche Stelle hat keinerlei Einfluss auf Inhalt und Gestaltung dieser Seiten; die Garantien dieser Datenschutzerklärung gelten daher für externe Anbieter nicht.",
  ]},
  { id: "cookies", level: 3, title: "1.7 Einsatz von Cookies", body: [
    "Die verantwortliche Stelle vermeidet Cookies weitgehend und verwendet diese nur, um die Online-Erfahrung individuell auszugestalten. Eingesetzt werden überwiegend Sitzungscookies (zur Login-Authentifizierung und zum Load-Balancing), die beim Verlassen des Browsers gelöscht werden, sowie permanente Cookies zur Speicherung persönlicher Nutzungseinstellungen.",
    "Der Besucher hat jederzeit die Möglichkeit, das Setzen von Cookies in den Einstellungen des Browsers abzulehnen. Dies kann den Leistungsumfang des Services mindern.",
  ]},
  { id: "analyse", level: 3, title: "1.8 Verwendung von Analyseprogrammen", body: [
    "Zur ständigen Verbesserung des Services werden anonymisierte oder pseudonymisierte Nutzungsprofile erstellt. Verwendet wird u. a. Google Analytics mit der Erweiterung „_anonymizeIp()“, wodurch IP-Adressen nur gekürzt verarbeitet werden. Der Datenerhebung kann jederzeit mit Wirkung für die Zukunft widersprochen werden.",
  ]},
  { id: "auskunft", level: 3, title: "1.9 Auskunftsrecht", body: [
    "Sie können nach den Vorschriften des Bundesdatenschutzgesetzes unentgeltlich Auskunft über Ihre gespeicherten Daten sowie ggf. Berichtigung, Sperrung oder Löschung dieser Daten verlangen.",
  ]},
  { id: "kontakt", level: 3, title: "1.10 Kontakt für Datenschutzfragen", body: [
    "Bei Fragen zur Erhebung, Verarbeitung und Nutzung Ihrer personenbezogenen Daten oder zur Wahrnehmung Ihrer Rechte wenden Sie sich bitte an info@ycat.de oder an: Yacht-Club am Tegernsee e.V., Seestraße 42, 83684 Tegernsee.",
  ]},
  { id: "hinweise", level: 2, title: "2. Weitere Rechtliche Hinweise", body: [] },
  { id: "haftung-inhalte", level: 3, title: "2.1 Haftung für Inhalte", body: [
    "Die Inhalte unserer Seiten wurden mit größter Sorgfalt erstellt. Für Richtigkeit, Vollständigkeit und Aktualität können wir jedoch keine Gewähr übernehmen. Als Diensteanbieter sind wir für eigene Inhalte verantwortlich, jedoch nicht verpflichtet, übermittelte oder gespeicherte fremde Informationen zu überwachen. Bei Bekanntwerden von Rechtsverletzungen entfernen wir entsprechende Inhalte umgehend.",
  ]},
  { id: "haftung-links", level: 3, title: "2.2 Haftung für Links", body: [
    "Unser Angebot enthält Links zu externen Webseiten Dritter, auf deren Inhalte wir keinen Einfluss haben. Für diese fremden Inhalte ist stets der jeweilige Anbieter verantwortlich. Bei Bekanntwerden von Rechtsverletzungen werden wir derartige Links umgehend entfernen.",
  ]},
  { id: "urheberrecht", level: 3, title: "2.3 Urheberrecht", body: [
    "Die durch die Seitenbetreiber erstellten Inhalte und Werke unterliegen dem deutschen Urheberrecht. Vervielfältigung, Bearbeitung, Verbreitung und jede Art der Verwertung außerhalb der Grenzen des Urheberrechts bedürfen der schriftlichen Zustimmung des jeweiligen Autors. Downloads und Kopien dieser Seite sind nur für den privaten, nicht kommerziellen Gebrauch gestattet.",
  ]},
];
const toc = sections.filter((s) => s.level === 2 || s.id === "cookies" || s.id === "analyse" || s.id === "urheberrecht");
---
<Layout title="Datenschutz & Rechtliche Hinweise" description="Datenschutzerklärung und rechtliche Hinweise des Yacht-Club am Tegernsee e.V.">
  <PageHero
    image={standard03}
    imageAlt="Segeln auf dem Tegernsee"
    kicker="Rechtliches"
    title="Datenschutz & Rechtliches"
    lede="Wie der YCaT mit Ihren Daten umgeht – und die rechtlichen Hinweise zu dieser Website."
    crumbs={[{ label: "Datenschutz & Rechtliches" }]}
    focus="center 55%"
  />

  <section class="section">
    <div class="container legal">
      <aside class="legal__toc">
        <p class="kicker">Inhalt</p>
        <nav>
          {sections.filter((s) => s.level === 2).map((s) => (
            <a href={`#${s.id}`}>{s.title}</a>
          ))}
        </nav>
      </aside>

      <div class="legal__body">
        {sections.map((s) => (
          <Reveal as="section" id={s.id} class={`legal__sec legal__sec--h${s.level}`}>
            {s.level === 2 ? <h2>{s.title}</h2> : <h3>{s.title}</h3>}
            {s.body.map((p) => <p>{p}</p>)}
          </Reveal>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .legal { display: grid; grid-template-columns: 240px 1fr; gap: clamp(1.6rem, 0.5rem + 4vw, 4rem); align-items: start; }
  .legal__toc { position: sticky; top: 6.5rem; }
  .legal__toc nav { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem; border-left: 1px solid var(--line); }
  .legal__toc a { padding: 0.3rem 0 0.3rem 1rem; margin-left: -1px; border-left: 2px solid transparent; font-size: 0.92rem; font-weight: 500; color: var(--muted); transition: color 0.2s, border-color 0.2s; }
  .legal__toc a:hover { color: var(--pine-800); border-color: var(--brass-500); }

  .legal__body { max-width: 70ch; }
  .legal__sec { scroll-margin-top: 6rem; }
  .legal__sec--h2 { margin-top: 2.6rem; padding-top: 2.2rem; border-top: 1px solid var(--line); }
  .legal__sec--h2:first-child { margin-top: 0; padding-top: 0; border-top: 0; }
  .legal__sec--h3 { margin-top: 1.8rem; }
  .legal__sec h2 { font-size: var(--step-2); }
  .legal__sec h3 { font-size: var(--step-1); color: var(--pine-800); }
  .legal__sec p { color: var(--ink-soft); margin-top: 0.7rem; font-size: 0.96rem; line-height: 1.7; }

  @media (max-width: 820px) {
    .legal { grid-template-columns: 1fr; }
    .legal__toc { position: static; display: none; }
  }
</style>
