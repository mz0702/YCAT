---
import Layout from "../components/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHead from "../components/SectionHead.astro";
import Reveal from "../components/Reveal.astro";
import Icon from "../components/Icon.astro";
import { regatta2026 } from "../data/schedule";
import { site } from "../data/site";
import regattaSpinnaker from "../assets/photos/regatta-spinnaker.jpg";

const clubs = [
  { code: "YCaT", name: "Yacht-Club am Tegernsee" },
  { code: "SVRE", name: "Segelverein Rottach-Egern" },
  { code: "YCBW", name: "Yacht Club Bad Wiessee" },
  { code: "TTYC", name: "Tegernseer Touring Yacht Club" },
];
const ycatCount = regatta2026.filter((r) => r.club === "YCaT").length;
---
<Layout title="Regatten am Tegernsee" description="Der Regattakalender am Tegernsee für die Saison 2026 – alle Wettfahrten der Vereine YCaT, SVRE, YCBW und TTYC im Überblick.">
  <PageHero
    image={regattaSpinnaker}
    imageAlt="Regattaboote mit Spinnaker auf dem Tegernsee"
    kicker="Regatta"
    title="Regatten am Tegernsee"
    lede="Die ganze Saison auf einen Blick – Silber-Serie, Meisterschaften und Klassiker der vier Tegernseer Vereine."
    crumbs={[{ label: "Regatten am Tegernsee" }]}
  />

  <section class="section">
    <div class="container">
      <div class="rk-head">
        <SectionHead kicker={`Saison 2026 · ${regatta2026.length} Termine`} title="Der Regattakalender" />
        <Reveal class="rk-actions">
          <a href={site.manage2sail} target="_blank" rel="noopener" class="btn btn--accent">
            Anmeldung & Ergebnisse <span class="btn__icon"><Icon name="arrow-up-right" size={15} /></span>
          </a>
          <span class="rk-actions__note">{ycatCount} Regatten richtet der YCaT selbst aus.</span>
        </Reveal>
      </div>

      <Reveal class="rk-legend">
        {clubs.map((c) => (
          <span class="rk-legend__item"><span class={`rk-badge rk-badge--${c.code.toLowerCase()}`}>{c.code}</span>{c.name}</span>
        ))}
      </Reveal>

      <Reveal class="rk-table" delay={60}>
        <div class="rk-row rk-row--head">
          <span>Datum</span><span>Klasse</span><span>Regatta</span><span>Veranstalter</span><span></span>
        </div>
        {regatta2026.map((r, i) => (
          <a href={r.href} target="_blank" rel="noopener" class="rk-row" style={`--reveal-delay:${Math.min(i, 12) * 30}ms`}>
            <span class="rk-row__date"><Icon name="calendar" size={15} />{r.date}</span>
            <span class="rk-row__class"><span class="tag tag--lake">{r.klasse}</span></span>
            <span class="rk-row__name">{r.name}</span>
            <span class="rk-row__club"><span class={`rk-badge rk-badge--${r.club.toLowerCase()}`}>{r.club}</span></span>
            <Icon name="arrow-up-right" size={16} class="rk-row__go" />
          </a>
        ))}
      </Reveal>
    </div>
  </section>
</Layout>

<style>
  .rk-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 1.8rem; }
  .rk-actions { display: flex; flex-direction: column; gap: 0.6rem; align-items: flex-start; }
  .rk-actions__note { font-size: 0.85rem; color: var(--muted); }

  .rk-legend { display: flex; flex-wrap: wrap; gap: 0.8rem 1.6rem; padding: 1.1rem 1.3rem; background: var(--surface); border-radius: var(--radius); margin-bottom: 1.6rem; }
  .rk-legend__item { display: inline-flex; align-items: center; gap: 0.55rem; font-size: 0.86rem; color: var(--ink-soft); font-weight: 500; }
  .rk-badge { display: inline-flex; align-items: center; padding: 0.22rem 0.55rem; border-radius: 6px; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.02em; }
  .rk-badge--ycat { background: oklch(0.41 0.06 155 / 0.16); color: var(--pine-700); }
  .rk-badge--svre { background: var(--lake-200); color: var(--lake-700); }
  .rk-badge--ycbw { background: var(--brass-200); color: var(--brass-600); }
  .rk-badge--ttyc { background: oklch(0.62 0.13 28 / 0.12); color: oklch(0.5 0.15 28); }

  .rk-table { border-top: 1px solid var(--line); }
  .rk-row { display: grid; grid-template-columns: 170px 110px 1fr 110px 24px; align-items: center; gap: 1.1rem; padding: 0.95rem 0.5rem; border-bottom: 1px solid var(--line); transition: background-color 0.25s, transform 0.4s var(--ease-expo); }
  .rk-row:not(.rk-row--head):hover { background: var(--surface); transform: translateX(6px); }
  .rk-row--head { font-size: 0.74rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); pointer-events: none; }
  .rk-row__date { display: inline-flex; align-items: center; gap: 0.45rem; font-weight: 600; color: var(--pine-700); font-variant-numeric: tabular-nums; font-size: 0.9rem; }
  .rk-row__date svg { color: var(--brass-500); flex-shrink: 0; }
  .rk-row__name { font-family: var(--font-display); font-size: 1.08rem; font-weight: 500; color: var(--pine-900); letter-spacing: -0.005em; }
  .rk-row__go { color: var(--line-strong); transition: color 0.3s, transform 0.4s var(--ease-expo); }
  .rk-row:hover .rk-row__go { color: var(--pine-700); transform: translate(2px, -2px); }

  @media (max-width: 820px) {
    .rk-row { grid-template-columns: 130px 1fr auto; row-gap: 0.4rem; }
    .rk-row__class { order: 3; }
    .rk-row__name { grid-column: 1 / -1; order: 4; }
    .rk-row__go, .rk-row--head { display: none; }
    .rk-row--head { display: none; }
  }
</style>
