---
import Layout from "../components/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Reveal from "../components/Reveal.astro";
import Icon from "../components/Icon.astro";
import { linkGroups } from "../data/partners";
import winterSail from "../assets/photos/winter-sail.jpg";

const groupIcon = ["anchor", "trophy", "pin", "compass"];
---
<Layout title="Links" description="Linksammlung des YCaT – Segelvereine am Tegernsee, Verbände, Tourismus im Tegernseer Tal und mehr.">
  <PageHero
    image={winterSail}
    imageAlt="Segeln auf dem Tegernsee"
    kicker="Service"
    title="Links rund um den See"
    lede="Befreundete Vereine, Verbände und nützliche Adressen aus dem Tegernseer Tal – auf einen Klick."
    crumbs={[{ label: "Links" }]}
    focus="center 45%"
  />

  <section class="section">
    <div class="container link-grid">
      {linkGroups.map((g, i) => (
        <Reveal as="section" class="link-card" delay={i * 70}>
          <div class="link-card__head">
            <span class="link-card__icon"><Icon name={groupIcon[i % groupIcon.length]} size={20} /></span>
            <h2>{g.title}</h2>
          </div>
          <ul>
            {g.links.map((l) => (
              <li>
                <a href={l.href} target="_blank" rel="noopener">
                  <span>{l.label}</span>
                  <Icon name="arrow-up-right" size={15} />
                </a>
              </li>
            ))}
          </ul>
        </Reveal>
      ))}
    </div>
  </section>
</Layout>

<style>
  .link-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.2rem; }
  .link-card { padding: clamp(1.6rem, 1rem + 2vw, 2.2rem); background: var(--white); border: 1px solid var(--line); border-radius: var(--radius-lg); }
  .link-card__head { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 0.6rem; }
  .link-card__icon { display: grid; place-items: center; width: 42px; height: 42px; border-radius: 12px; background: var(--lake-200); color: var(--lake-700); flex-shrink: 0; }
  .link-card h2 { font-size: var(--step-1); }
  .link-card ul { list-style: none; padding: 0; margin-top: 0.6rem; }
  .link-card li { border-top: 1px solid var(--line); }
  .link-card a { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; padding: 0.85rem 0.2rem; color: var(--ink-soft); font-weight: 500; transition: color 0.2s, transform 0.3s var(--ease-expo); }
  .link-card a:hover { color: var(--lake-700); transform: translateX(5px); }
  .link-card a svg { color: var(--line-strong); flex-shrink: 0; transition: color 0.2s, transform 0.4s var(--ease-expo); }
  .link-card a:hover svg { color: var(--lake-600); transform: translate(2px, -2px); }

  @media (max-width: 760px) { .link-grid { grid-template-columns: 1fr; } }
</style>
