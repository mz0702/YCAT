---
import Layout from "../../components/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHead from "../../components/SectionHead.astro";
import Reveal from "../../components/Reveal.astro";
import Icon from "../../components/Icon.astro";
import JoinCta from "../../components/JoinCta.astro";
import { boatGroups, förderklassen, bootsklassenIntro, klassenpolitik } from "../../data/boats";
import regattaSpinnaker from "../../assets/photos/regatta-spinnaker.jpg";
const groupIcon = ["sail", "wind", "anchor"];
---
<Layout title="Bootsklassen" description="Die Bootsklassen im Yacht-Club am Tegernsee – Jugendboote, Jollen und Kielboote sowie die Klassenpolitik des Vereins.">
  <PageHero
    image={regattaSpinnaker}
    imageAlt="Segelboote mit Spinnaker auf dem Tegernsee"
    kicker="Der YCaT"
    title="Bootsklassen am See"
    lede="Der YCaT fördert reviergeeignete Einheitsklassen – für große, attraktive Felder bei Regatten und starke Flotten im Verein."
    crumbs={[{ label: "Der YCaT", href: "/der-ycat/" }, { label: "Bootsklassen" }]}
  />

  <section class="section">
    <div class="container">
      <Reveal as="p" class="lede bk-intro">{bootsklassenIntro}</Reveal>

      <div class="bk-groups">
        {boatGroups.map((g, i) => (
          <Reveal as="article" class="bk-group" delay={i * 80}>
            <div class="bk-group__head">
              <span class="bk-group__icon"><Icon name={groupIcon[i]} size={22} /></span>
              <div>
                <h2 class="bk-group__title">{g.group}</h2>
                <p class="bk-group__blurb">{g.blurb}</p>
              </div>
            </div>
            <ul class="bk-chips">
              {g.classes.map((c) => <li class="bk-chip">{c}</li>)}
            </ul>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="section-sm bg-surface">
    <div class="container bk-policy">
      <div>
        <SectionHead kicker="Außerhalb der Klassenpolitik" title="Geförderte Zukunftsklassen" />
        <Reveal as="p" class="prose bk-policy__p" delay={80}>{klassenpolitik}</Reveal>
      </div>
      <Reveal class="bk-foerder" delay={120}>
        <p class="kicker">In Förderung</p>
        <ul class="bk-chips bk-chips--ghost">
          {förderklassen.map((c) => <li class="bk-chip bk-chip--ghost">{c}</li>)}
        </ul>
        <p class="bk-foerder__note">
          <Icon name="flag" size={16} />
          Fragen zu einer Klasse? Wendet euch an den zuständigen
          <a href="/der-ycat/obleute/">Obmann</a> oder die Geschäftsstelle.
        </p>
      </Reveal>
    </div>
  </section>

  <JoinCta />
</Layout>

<style>
  .bk-intro { max-width: 70ch; }
  .bk-groups { display: flex; flex-direction: column; gap: 1rem; margin-top: 2.6rem; }
  .bk-group { padding: clamp(1.5rem, 1rem + 2vw, 2.4rem); background: var(--white); border: 1px solid var(--line); border-radius: var(--radius-lg); transition: box-shadow 0.4s var(--ease-expo); }
  .bk-group:hover { box-shadow: var(--shadow-md); }
  .bk-group__head { display: flex; gap: 1.2rem; align-items: flex-start; }
  .bk-group__icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 14px; background: var(--pine-800); color: var(--brass-400); flex-shrink: 0; }
  .bk-group__title { font-size: var(--step-2); }
  .bk-group__blurb { color: var(--muted); margin-top: 0.4rem; max-width: 60ch; }
  .bk-chips { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1.4rem; }
  .bk-chip {
    padding: 0.6rem 1.1rem; border-radius: 999px;
    background: var(--lake-200); color: var(--lake-700);
    font-weight: 600; font-size: 0.95rem; letter-spacing: -0.005em;
    transition: transform 0.35s var(--ease-expo), background-color 0.25s;
  }
  .bk-chip:hover { transform: translateY(-2px); background: var(--lake-400); color: var(--pine-950); }
  .bk-chip--ghost { background: transparent; border: 1px solid var(--line-strong); color: var(--pine-700); }
  .bk-chip--ghost:hover { background: var(--pine-800); color: var(--white); border-color: var(--pine-800); }

  .bk-policy { display: grid; grid-template-columns: 1.3fr 1fr; gap: clamp(1.6rem, 0.5rem + 4vw, 4rem); align-items: start; }
  .bk-policy__p { margin-top: 1.2rem; }
  .bk-foerder { padding: 1.8rem; background: var(--white); border: 1px solid var(--line); border-radius: var(--radius-lg); }
  .bk-foerder__note { display: flex; gap: 0.6rem; align-items: flex-start; margin-top: 1.4rem; padding-top: 1.4rem; border-top: 1px solid var(--line); font-size: 0.9rem; color: var(--muted); }
  .bk-foerder__note svg { color: var(--brass-500); flex-shrink: 0; margin-top: 2px; }
  .bk-foerder__note a { color: var(--lake-700); text-decoration: underline; text-underline-offset: 3px; margin-inline: 0.15rem; }

  @media (max-width: 860px) { .bk-policy { grid-template-columns: 1fr; } }
</style>
