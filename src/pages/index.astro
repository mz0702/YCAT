---
import Layout from "../components/Layout.astro";
import Reveal from "../components/Reveal.astro";
import SectionHead from "../components/SectionHead.astro";
import Icon from "../components/Icon.astro";
import { Image } from "astro:assets";
import { site } from "../data/site";
import { boatGroups } from "../data/boats";
import { regatta2026 } from "../data/schedule";
import { news } from "../data/news";

import optiFleet from "../assets/photos/opti-fleet.jpg";
import youthGroup from "../assets/photos/youth-group.jpg";
import regatta420 from "../assets/photos/regatta-420.jpg";
import keelboatCrane from "../assets/photos/keelboat-crane.jpg";
import aqua from "../assets/photos/aqua.jpg";
import clubhouse from "../assets/photos/clubhouse.jpg";
import lakePanorama from "../assets/photos/lake-panorama.jpg";

const allClasses = boatGroups.flatMap((g) => g.classes);
const marquee = [...allClasses, "Olympiaklassen", "Tradition seit 1931"];
const nextRegatten = regatta2026.slice(2, 8);
const categoryClass = { Regatta: "tag--lake", Jugend: "tag--brass", Verein: "tag--pine" } as const;
---
<Layout>
  <!-- ============ HERO ============ -->
  <section class="hero on-dark">
    <div class="hero__media" data-parallax data-speed="0.10">
      <Image src={optiFleet} alt="Optimisten-Flotte des YCaT auf dem türkisfarbenen Tegernsee vor den Bayerischen Alpen"
        class="hero__img" widths={[900, 1400, 2000]} sizes="100vw" loading="eager" fetchpriority="high" />
    </div>
    <div class="hero__scrim" aria-hidden="true"></div>

    <div class="container hero__inner">
      <p class="kicker hero__kicker">Yacht-Club am Tegernsee · seit {site.founded}</p>
      <h1 class="hero__title">
        <span class="line"><span>Faszination</span></span>
        <span class="line"><span>Segelsport.</span></span>
        <span class="line line--accent"><span>Ein Leben lang.</span></span>
      </h1>
      <p class="hero__lede">
        Segelsport und mehr am schönsten Voralpensee – vom ersten Schlag im Optimist
        bis zur internationalen Regatta. Tradition, Talentförderung und das
        Tegernseer Tal als Revier.
      </p>
      <div class="hero__cta">
        <a href="/jugend/" class="btn btn--accent">
          Jugend &amp; Segelkurse <span class="btn__icon"><Icon name="arrow-right" size={16} /></span>
        </a>
        <a href="/regatten-am-tegernsee/" class="btn btn--ghost">
          Regatten 2026 <span class="btn__icon"><Icon name="arrow-up-right" size={15} /></span>
        </a>
      </div>

      <div class="hero__quick">
        <a href={site.manage2sail} target="_blank" rel="noopener" class="quick">
          <Icon name="trophy" size={19} /> <span>Regatten</span> <em>manage2sail</em>
          <Icon name="arrow-up-right" size={14} class="quick__ext" />
        </a>
        <a href="/jugend/segelkurse/" class="quick">
          <Icon name="sail" size={19} /> <span>Jugend-Segelkurse</span> <em>2026</em>
          <Icon name="arrow-right" size={14} class="quick__ext" />
        </a>
        <a href={site.restaurant} target="_blank" rel="noopener" class="quick">
          <Icon name="waves" size={19} /> <span>Aqua Ristorante</span> <em>im YCaT</em>
          <Icon name="arrow-up-right" size={14} class="quick__ext" />
        </a>
      </div>
    </div>

    <a href="#intro" class="hero__scroll" aria-label="Weiter scrollen">
      <span class="hero__scroll-line"></span>
    </a>
    <div class="hero__fade" aria-hidden="true"></div>
  </section>

  <!-- ============ INTRO + STATS ============ -->
  <section class="section" id="intro">
    <div class="container intro">
      <div class="intro__lead">
        <Reveal><p class="kicker">Der Yacht-Club am Tegernsee</p></Reveal>
        <Reveal as="h2" delay={60} class="intro__title">
          Ein sportlicher Club mit großer Geschichte – und einem Revier, das jeden Schlag lohnt.
        </Reveal>
      </div>
      <div class="intro__body">
        <Reveal as="p" delay={120} class="lede">
          Gegründet 1931, beheimatet im Herzoglichen Haus direkt am Wasser. Aus den sportlichen
          Aktivitäten gingen Bayerische, Deutsche, Österreichische und Schweizer Meister,
          Europa-Cup-Sieger, Weltmeister und Olympiateilnehmer hervor – eine Tradition, die heute
          vor allem im Jugendbereich weitergeschrieben wird.
        </Reveal>
        <Reveal class="stats" delay={180}>
          <div class="stat">
            <span class="stat__num">1931</span>
            <span class="stat__label">Gegründet am Tegernsee</span>
          </div>
          <div class="stat">
            <span class="stat__num" data-count={regatta2026.length} data-suffix="">0</span>
            <span class="stat__label">Regatten in der Saison 2026</span>
          </div>
          <div class="stat">
            <span class="stat__num" data-count={allClasses.length} data-suffix="">0</span>
            <span class="stat__label">aktiv geförderte Bootsklassen</span>
          </div>
          <div class="stat">
            <span class="stat__num">ab&nbsp;6</span>
            <span class="stat__label">Jahren ins Jugendsegeln</span>
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ============ ERLEBNISWELTEN (bento) ============ -->
  <section class="section-sm">
    <div class="container">
      <SectionHead kicker="Was den YCaT ausmacht"
        title="Vier Welten, ein Verein"
        lede="Vom Nachwuchs auf dem Wasser über den Regattasport bis zum Hafen und der Küche am See." />
      <div class="bento" data-reveal>
        <a href="/jugend/" class="tile tile--jugend">
          <Image src={youthGroup} alt="Junge Seglerinnen und Segler des YCaT bei einer Regatta" class="tile__img"
            widths={[600, 1000]} sizes="(max-width:780px) 100vw, 55vw" />
          <div class="tile__scrim"></div>
          <div class="tile__body">
            <span class="tile__eyebrow"><Icon name="sail" size={16} /> Next Generation Sailing</span>
            <h3>Jugend &amp; Segelkurse</h3>
            <p>Von der Sailing Lounge bis zum Sportsclub – Segeln lernen, Talente fördern, Freunde finden.</p>
            <span class="tile__go">Mehr entdecken <Icon name="arrow-right" size={16} /></span>
          </div>
        </a>

        <a href="/regatten-am-tegernsee/" class="tile tile--regatta">
          <Image src={regatta420} alt="Regattaboote am Tegernsee" class="tile__img" widths={[500, 800]} sizes="40vw" />
          <div class="tile__scrim"></div>
          <div class="tile__body">
            <span class="tile__eyebrow"><Icon name="trophy" size={16} /> Saison 2026</span>
            <h3>Regatta</h3>
            <p>Silber-Serie, Meisterschaften &amp; Klassiker auf dem See.</p>
            <span class="tile__go">Kalender <Icon name="arrow-right" size={16} /></span>
          </div>
        </a>

        <a href="/hafen/" class="tile tile--hafen">
          <Image src={keelboatCrane} alt="Kielboot am Kran des YCaT-Hafens" class="tile__img" widths={[500, 800]} sizes="40vw" />
          <div class="tile__scrim"></div>
          <div class="tile__body">
            <span class="tile__eyebrow"><Icon name="anchor" size={16} /> Am Wasser</span>
            <h3>Hafen &amp; Liegeplätze</h3>
            <p>Kran-Service, Liegeplätze und Arbeitsdienst.</p>
            <span class="tile__go">Zum Hafen <Icon name="arrow-right" size={16} /></span>
          </div>
        </a>

        <a href={site.restaurant} target="_blank" rel="noopener" class="tile tile--aqua">
          <Image src={aqua} alt="Aqua Ristorante im YCaT" class="tile__img" widths={[600, 1100]} sizes="100vw" />
          <div class="tile__scrim tile__scrim--side"></div>
          <div class="tile__body">
            <span class="tile__eyebrow"><Icon name="waves" size={16} /> Genuss am See</span>
            <h3>Aqua Ristorante Tegernsee</h3>
            <p>Italienische Küche mit Seeblick, direkt im Clubhaus des YCaT.</p>
            <span class="tile__go">Zum Ristorante <Icon name="arrow-up-right" size={15} /></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ HERITAGE SPLIT ============ -->
  <section class="section heritage">
    <div class="container heritage__grid">
      <Reveal class="heritage__media">
        <Image src={clubhouse} alt="Das Clubhaus des YCaT – das Herzogliche Haus am Tegernsee" class="heritage__img"
          widths={[600, 1000]} sizes="(max-width:880px) 100vw, 48vw" />
        <div class="heritage__badge">
          <span class="heritage__badge-num">est.</span>
          <span class="heritage__badge-year">1931</span>
        </div>
      </Reveal>
      <div class="heritage__text">
        <SectionHead kicker="Tradition" title="Beheimatet im Herzoglichen Haus" />
        <Reveal as="p" delay={80} class="prose heritage__p">
          Der Yacht-Club am Tegernsee wurde 1931 auf Initiative einiger Mitglieder des Königlich
          Bayerischen Yachtclubs Starnberg gegründet. Nach dem Zweiten Weltkrieg erfolgte 1949 eine
          Neugründung, 1955 entstand der heutige Yacht-Club am Tegernsee.
        </Reveal>
        <Reveal as="p" delay={140} class="prose heritage__p">
          Seine lange Erfolgsgeschichte – von Bayerischen und Deutschen Meistern bis zu Weltmeistern
          und Olympiateilnehmern – wird heute besonders im Nachwuchs der 29er-Klasse und im
          aufstrebenden Optimist-Bereich fortgesetzt.
        </Reveal>
        <Reveal delay={200} class="heritage__cta">
          <a href="/der-ycat/" class="link-arrow">Mehr über den Verein <Icon name="arrow-right" size={16} /></a>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ============ BOOTSKLASSEN MARQUEE ============ -->
  <section class="marquee-band on-dark bg-pine-deep" aria-label="Bootsklassen im YCaT">
    <div class="marquee" aria-hidden="true">
      <div class="marquee__track">
        {marquee.map((c) => <span class="marquee__item">{c}<span class="marquee__dot">✦</span></span>)}
        {marquee.map((c) => <span class="marquee__item">{c}<span class="marquee__dot">✦</span></span>)}
      </div>
    </div>
    <p class="marquee__cap container">
      <span>Optimist bis Drachen – </span>
      <a href="/der-ycat/bootsklassen/" class="link-arrow">alle Bootsklassen <Icon name="arrow-right" size={15} /></a>
    </p>
  </section>

  <!-- ============ REGATTA TEASER ============ -->
  <section class="section regatta-teaser">
    <div class="container regatta-teaser__head">
      <SectionHead kicker="Regattakalender · Saison 2026" title="Als Nächstes am Start" />
      <Reveal class="regatta-teaser__actions">
        <a href="/regatten-am-tegernsee/" class="link-arrow">Gesamter Kalender <Icon name="arrow-right" size={16} /></a>
      </Reveal>
    </div>
    <div class="container">
      <Reveal class="rt-list">
        {nextRegatten.map((r, i) => (
          <a href={r.href} target="_blank" rel="noopener" class="rt-row" style={`--reveal-delay:${i * 50}ms`}>
            <span class="rt-row__date"><Icon name="calendar" size={16} />{r.date}</span>
            <span class="rt-row__name">{r.name}</span>
            <span class="rt-row__class"><span class="tag tag--lake">{r.klasse}</span></span>
            <span class="rt-row__club">{r.club}</span>
            <Icon name="arrow-up-right" size={16} class="rt-row__go" />
          </a>
        ))}
      </Reveal>
    </div>
  </section>

  <!-- ============ NEWS ============ -->
  <section class="section-sm news-sec bg-surface">
    <div class="container news-sec__head">
      <SectionHead kicker="Aktuelles" title="Frischer Wind vom See" />
      <Reveal class="news-sec__actions">
        <a href="/aktuelles/" class="link-arrow">Alle News <Icon name="arrow-right" size={16} /></a>
      </Reveal>
    </div>
    <div class="container news-grid">
      {news.map((n, i) => (
        <Reveal as="article" class="news-card" delay={i * 90}>
          <div class="news-card__top">
            <span class={`tag ${categoryClass[n.category]}`}>{n.category}</span>
            <time class="news-card__date">{n.date}</time>
          </div>
          <h3 class="news-card__title">{n.title}</h3>
          <p class="news-card__excerpt">{n.excerpt}</p>
          {n.result && (
            <ul class="news-card__result">
              {n.result.map((r) => <li><span>{r.place}</span> {r.crew}</li>)}
            </ul>
          )}
          <a href={n.href} target="_blank" rel="noopener" class="news-card__link">
            Weiterlesen auf Facebook <Icon name="arrow-up-right" size={14} />
          </a>
        </Reveal>
      ))}
    </div>
  </section>

  <!-- ============ TEGERNSEE LOCATION ============ -->
  <section class="location on-dark">
    <div class="location__media" data-parallax data-speed="0.06">
      <Image src={lakePanorama} alt="Blick über den Tegernsee mit den Bayerischen Alpen" class="location__img"
        widths={[900, 1500, 2000]} sizes="100vw" />
    </div>
    <div class="location__scrim" aria-hidden="true"></div>
    <div class="container location__inner">
      <Reveal>
        <p class="kicker">Unser Revier</p>
        <h2 class="location__title">Der Tegernsee – Berg-, Tal- und Föhnwind inklusive.</h2>
        <p class="lede location__lede">
          Am Nordrand der Bayerischen Alpen prägt ein thermisches Windsystem das Revier: der
          vorherrschende Nordost-Talwind mit 3–4 Beaufort, dazu Bergwind, West-Lagen und der
          legendäre Föhn. Ein See, der jeden Tag anders segelt.
        </p>
        <div class="location__cta">
          <a href="/wind-und-wetter/" class="btn btn--ghost">Wind &amp; Wetter <span class="btn__icon"><Icon name="wind" size={16} /></span></a>
          <a href="/kontakt/" class="link-arrow location__anfahrt">Anfahrt &amp; Kontakt <Icon name="arrow-right" size={16} /></a>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="section join bg-pine-deep on-dark">
    <div class="container join__inner">
      <Reveal>
        <p class="kicker">Mitglied werden</p>
        <h2 class="join__title">Lust, mit uns zu segeln?</h2>
        <p class="lede join__lede">
          Ob Familie, Nachwuchstalent oder ambitionierter Regattasegler – der YCaT freut sich auf
          neue Gesichter. Komm vorbei, schnupper Seeluft und werde Teil des Vereins.
        </p>
      </Reveal>
      <Reveal class="join__cta" delay={120}>
        <a href="/kontakt/" class="btn btn--accent">Kontakt aufnehmen <span class="btn__icon"><Icon name="arrow-right" size={16} /></span></a>
        <a href="https://www.ycat.de/wp-content/uploads/2014/04/Aufnahmeantrag-zur-Aufnahme-als-Mitglied-in-den-YCaT-Version-2017.pdf"
          target="_blank" rel="noopener" class="btn btn--ghost">
          Aufnahmeantrag (PDF) <span class="btn__icon"><Icon name="download" size={15} /></span>
        </a>
      </Reveal>
    </div>
  </section>
</Layout>

<style>
  /* ---------------- HERO ---------------- */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding-top: 9rem;
    padding-bottom: clamp(2rem, 1rem + 4vw, 3.5rem);
    overflow: clip;
    isolation: isolate;
  }
  .hero__media { position: absolute; inset: -10% 0; z-index: -2; }
  .hero__img {
    width: 100%; height: 100%; object-fit: cover; object-position: center 45%;
    transform: translateY(var(--py, 0)) scale(1.06);
    animation: kenburns 26s ease-in-out infinite alternate;
  }
  @keyframes kenburns { from { scale: 1.04; } to { scale: 1.12; } }
  .hero__scrim {
    position: absolute; inset: 0; z-index: -1;
    background:
      linear-gradient(to top, oklch(0.17 0.022 158 / 0.94) 2%, oklch(0.18 0.025 158 / 0.5) 38%, oklch(0.2 0.03 160 / 0.12) 72%),
      linear-gradient(100deg, oklch(0.17 0.022 158 / 0.6), transparent 55%);
  }
  .hero__fade { position: absolute; inset: auto 0 0 0; height: 110px; z-index: -1; background: linear-gradient(to bottom, transparent, var(--paper)); }
  .hero__inner { position: relative; max-width: 1000px; }
  .hero__kicker { color: var(--brass-400); margin-bottom: 1.4rem; }
  .hero__kicker::before { background: var(--brass-400); }
  .hero__title {
    font-size: clamp(2.7rem, 1.4rem + 6.2vw, 5.6rem);
    font-weight: 410;
    line-height: 0.96;
    letter-spacing: -0.025em;
    color: var(--white);
  }
  .hero__title .line { display: block; overflow: hidden; padding-bottom: 0.04em; }
  .hero__title .line > span { display: block; transform: translateY(110%); animation: lineUp 1s var(--ease-expo) forwards; }
  .hero__title .line:nth-child(1) > span { animation-delay: 0.15s; }
  .hero__title .line:nth-child(2) > span { animation-delay: 0.28s; }
  .hero__title .line:nth-child(3) > span { animation-delay: 0.41s; }
  .line--accent > span {
    font-style: italic;
    color: var(--brass-400);
    font-variation-settings: "opsz" 130;
  }
  @keyframes lineUp { to { transform: translateY(0); } }
  .hero__lede {
    margin-top: 1.6rem; max-width: 50ch;
    font-size: var(--step-1); line-height: 1.5;
    color: oklch(0.95 0.01 165 / 0.92);
    opacity: 0; animation: fadeUp 0.9s var(--ease-expo) 0.6s forwards;
  }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 2rem; opacity: 0; animation: fadeUp 0.9s var(--ease-expo) 0.74s forwards; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: none; } }

  .hero__quick {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.7rem;
    margin-top: 2.6rem; max-width: 760px;
    opacity: 0; animation: fadeUp 0.9s var(--ease-expo) 0.9s forwards;
  }
  .quick {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.9rem 1.05rem; border-radius: var(--radius);
    background: oklch(1 0 0 / 0.08);
    border: 1px solid oklch(1 0 0 / 0.12);
    backdrop-filter: blur(8px);
    color: var(--white); font-weight: 600; font-size: 0.92rem;
    transition: background-color 0.3s, transform 0.4s var(--ease-expo), border-color 0.3s;
  }
  .quick svg:first-child { color: var(--brass-400); flex-shrink: 0; }
  .quick span { white-space: nowrap; }
  .quick em { font-style: normal; font-weight: 500; color: var(--on-dark-muted); font-size: 0.82rem; margin-left: auto; }
  .quick__ext { color: var(--on-dark-muted); margin-left: 0.1rem; transition: transform 0.35s var(--ease-expo); }
  .quick:hover { background: oklch(1 0 0 / 0.14); transform: translateY(-2px); border-color: oklch(1 0 0 / 0.25); }
  .quick:hover .quick__ext { transform: translate(2px, -2px); }

  .hero__scroll { position: absolute; left: 50%; bottom: 1.6rem; translate: -50% 0; width: 26px; height: 44px; border: 1px solid oklch(1 0 0 / 0.3); border-radius: 999px; display: grid; place-items: start center; padding-top: 7px; z-index: 1; }
  .hero__scroll-line { width: 2px; height: 9px; border-radius: 2px; background: var(--brass-400); animation: scrolldot 1.8s var(--ease-quart) infinite; }
  @keyframes scrolldot { 0% { opacity: 0; transform: translateY(-4px); } 40% { opacity: 1; } 80%,100% { opacity: 0; transform: translateY(12px); } }

  /* ---------------- INTRO ---------------- */
  .intro { display: grid; grid-template-columns: 1fr 1.15fr; gap: clamp(1.6rem, 0.5rem + 4vw, 4.5rem); align-items: start; }
  .intro__title { font-size: var(--step-3); }
  .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.4rem 2rem; margin-top: 2.6rem; padding-top: 2.2rem; border-top: 1px solid var(--line); }
  .stat { display: flex; flex-direction: column; gap: 0.3rem; }
  .stat__num { font-family: var(--font-display); font-size: clamp(2.1rem, 1.4rem + 2.4vw, 3rem); font-weight: 460; line-height: 1; letter-spacing: -0.02em; color: var(--pine-700); font-variant-numeric: tabular-nums; }
  .stat__label { font-size: 0.92rem; color: var(--muted); font-weight: 500; }

  /* ---------------- BENTO ---------------- */
  .bento { display: grid; grid-template-columns: repeat(12, 1fr); gap: 1rem; margin-top: 2.8rem; }
  .tile {
    position: relative; overflow: hidden; border-radius: var(--radius-lg);
    min-height: 230px; display: flex; align-items: flex-end; isolation: isolate;
    box-shadow: var(--shadow-sm);
  }
  .tile--jugend { grid-column: span 7; grid-row: span 2; min-height: 480px; }
  .tile--regatta { grid-column: span 5; }
  .tile--hafen { grid-column: span 5; }
  .tile--aqua { grid-column: span 12; min-height: 270px; }
  .tile__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; transition: transform 1s var(--ease-expo); }
  .tile__scrim { position: absolute; inset: 0; z-index: -1; background: linear-gradient(to top, oklch(0.16 0.02 158 / 0.9) 6%, oklch(0.17 0.022 158 / 0.25) 55%, transparent 80%); }
  .tile__scrim--side { background: linear-gradient(95deg, oklch(0.16 0.02 158 / 0.92) 18%, oklch(0.16 0.02 158 / 0.4) 52%, transparent 78%); }
  .tile__body { padding: clamp(1.3rem, 1rem + 1.5vw, 2.1rem); color: var(--white); max-width: 46ch; }
  .tile--aqua .tile__body { max-width: 38ch; }
  .tile__eyebrow { display: inline-flex; align-items: center; gap: 0.45rem; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.01em; color: var(--brass-400); margin-bottom: 0.7rem; }
  .tile__body h3 { color: var(--white); font-size: var(--step-2); }
  .tile--jugend .tile__body h3 { font-size: var(--step-3); }
  .tile__body p { color: oklch(0.93 0.01 165 / 0.85); margin-top: 0.5rem; font-size: 0.96rem; }
  .tile__go { display: inline-flex; align-items: center; gap: 0.45rem; margin-top: 1rem; font-weight: 600; font-size: 0.92rem; color: var(--white); transition: gap 0.3s var(--ease-expo); }
  .tile:hover .tile__img { transform: scale(1.05); }
  .tile:hover .tile__go { gap: 0.75rem; }

  /* ---------------- HERITAGE ---------------- */
  .heritage__grid { display: grid; grid-template-columns: 0.95fr 1fr; gap: clamp(1.6rem, 0.5rem + 4vw, 4rem); align-items: center; }
  .heritage__media { position: relative; }
  .heritage__img { width: 100%; border-radius: var(--radius-lg); aspect-ratio: 4/3.4; object-fit: cover; box-shadow: var(--shadow-lg); }
  .heritage__badge {
    position: absolute; right: -14px; bottom: -14px;
    background: var(--brass-500); color: var(--pine-950);
    border-radius: 18px; padding: 0.9rem 1.2rem; text-align: center;
