---
import Layout from "../components/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Reveal from "../components/Reveal.astro";
import Icon from "../components/Icon.astro";
import { news } from "../data/news";
import { site } from "../data/site";
import regattaFleet from "../assets/photos/regatta-fleet.jpg";

const categoryClass = { Regatta: "tag--lake", Jugend: "tag--brass", Verein: "tag--pine" } as const;
---
<Layout title="Aktuelles" description="Aktuelles vom Yacht-Club am Tegernsee – Regattaberichte, Jugend-Erfolge und Neuigkeiten aus dem Vereinsleben.">
  <PageHero
    image={regattaFleet}
    imageAlt="Regattaboote auf dem Tegernsee"
    kicker="News"
    title="Frischer Wind vom See"
    lede="Regattaberichte, Jugend-Erfolge und Neuigkeiten aus dem Vereinsleben – direkt von unserer Facebook-Seite."
    crumbs={[{ label: "Aktuelles" }]}
  />

  <section class="section">
    <div class="container">
      <div class="feed">
        {news.map((n, i) => (
          <Reveal as="article" class="feed-item" delay={i * 70}>
            <div class="feed-item__meta">
              <span class={`tag ${categoryClass[n.category]}`}>{n.category}</span>
              <time>{n.date}</time>
            </div>
            <div class="feed-item__body">
              <h2 class="feed-item__title">{n.title}</h2>
              <p class="feed-item__excerpt">{n.excerpt}</p>
              {n.result && (
                <ul class="feed-item__result">
                  {n.result.map((r) => <li><span>{r.place}</span> {r.crew}</li>)}
                </ul>
              )}
              <a href={n.href} target="_blank" rel="noopener" class="link-arrow">Auf Facebook ansehen <Icon name="arrow-up-right" size={15} /></a>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      <Reveal class="fb-band">
        <div class="fb-band__icon"><Icon name="facebook" size={28} /></div>
        <div class="fb-band__text">
          <h2>Immer auf dem Laufenden</h2>
          <p>Wir posten Ergebnisse, Fotos und Termine zuerst auf Facebook. Folge dem YCaT und verpasse keine Regatta mehr.</p>
        </div>
        <a href={site.facebook} target="_blank" rel="noopener" class="btn btn--accent">
          YCaT auf Facebook <span class="btn__icon"><Icon name="arrow-up-right" size={15} /></span>
        </a>
      </Reveal>
    </div>
  </section>
</Layout>

<style>
  .feed { max-width: 820px; margin-inline: auto; display: flex; flex-direction: column; }
  .feed-item { display: grid; grid-template-columns: 150px 1fr; gap: 1.6rem; padding: 2rem 0; border-top: 1px solid var(--line); }
  .feed-item:first-child { border-top: 0; padding-top: 0; }
  .feed-item__meta { display: flex; flex-direction: column; gap: 0.6rem; }
  .feed-item__meta time { font-size: 0.86rem; color: var(--muted); font-weight: 500; }
  .feed-item__title { font-size: var(--step-2); }
  .feed-item__excerpt { color: var(--ink-soft); margin-top: 0.7rem; }
  .feed-item__result { list-style: none; padding: 1rem 1.2rem; margin: 1.2rem 0; background: var(--surface); border-radius: 12px; display: flex; flex-direction: column; gap: 0.4rem; }
  .feed-item__result li { font-size: 0.92rem; color: var(--ink-soft); font-weight: 500; }
  .feed-item .link-arrow { margin-top: 1rem; color: var(--lake-700); }

  .fb-band { display: flex; align-items: center; gap: 1.4rem; flex-wrap: wrap; padding: clamp(1.6rem, 1rem + 2vw, 2.4rem); background: var(--pine-900); color: var(--on-dark); border-radius: var(--radius-lg); }
  .fb-band__icon { display: grid; place-items: center; width: 60px; height: 60px; border-radius: 18px; background: oklch(1 0 0 / 0.1); color: var(--brass-400); flex-shrink: 0; }
  .fb-band__text { flex: 1; min-width: 220px; }
  .fb-band__text h2 { color: var(--white); font-size: var(--step-2); }
  .fb-band__text p { color: oklch(0.92 0.01 165 / 0.85); margin-top: 0.4rem; max-width: 50ch; }

  @media (max-width: 700px) {
    .feed-item { grid-template-columns: 1fr; gap: 0.9rem; }
    .feed-item__meta { flex-direction: row; align-items: center; gap: 1rem; }
  }
</style>
