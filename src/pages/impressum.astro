---
import Layout from "../components/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Reveal from "../components/Reveal.astro";
import Icon from "../components/Icon.astro";
import clubhouse from "../assets/photos/clubhouse.jpg";

const facts = [
  { label: "Verein", value: "Yacht-Club am Tegernsee e.V." },
  { label: "Anschrift", value: "Seestraße 42, 83684 Tegernsee" },
  { label: "Vereinsregister", value: "AG München, Nr. 60069" },
  { label: "USt-IdNr.", value: "DE 131 208 332" },
  { label: "Vertretungsberechtigter Vorstand", value: "Dr. Alexander Oswald (1. Vorsitzender)" },
  { label: "Inhaltlich verantwortlich (§ 10 Abs. 3 MDStV)", value: "Dr. Alexander Oswald" },
];
---
<Layout title="Impressum" description="Impressum des Yacht-Club am Tegernsee e.V.">
  <PageHero
    image={clubhouse}
    imageAlt="Das Clubhaus des YCaT"
    kicker="Rechtliches"
    title="Impressum"
    crumbs={[{ label: "Impressum" }]}
    focus="center 50%"
  />

  <section class="section">
    <div class="container imp">
      <Reveal class="imp__facts">
        <dl>
          {facts.map((f) => (
            <div class="imp__row">
              <dt>{f.label}</dt>
              <dd>{f.value}</dd>
            </div>
          ))}
        </dl>
      </Reveal>

      <Reveal class="imp__side" delay={100}>
        <div class="imp__contact">
          <p class="kicker">Kontakt</p>
          <ul>
            <li><Icon name="phone" size={17} /><a href="tel:+49802210114">+49 (0)8022 10114</a></li>
            <li><Icon name="external" size={17} /><span>Fax +49 (0)8022 10176</span></li>
            <li><Icon name="mail" size={17} /><a href="mailto:info@ycat.de">info@ycat.de</a></li>
            <li><Icon name="compass" size={17} /><a href="https://www.ycat.de" target="_blank" rel="noopener">www.ycat.de</a></li>
          </ul>
        </div>
        <p class="imp__haftung">
          <strong>Haftungshinweis:</strong> Trotz sorgfältiger inhaltlicher Kontrolle übernehmen wir
          keine Haftung für die Inhalte externer Links. Für den Inhalt der verlinkten Seiten sind
          ausschließlich deren Betreiber verantwortlich.
        </p>
        <a href="/rechtlicher-hinweis/" class="link-arrow">Datenschutz & Rechtliche Hinweise <Icon name="arrow-right" size={15} /></a>
      </Reveal>
    </div>
  </section>
</Layout>

<style>
  .imp { display: grid; grid-template-columns: 1.4fr 1fr; gap: clamp(1.6rem, 0.5rem + 4vw, 3.5rem); align-items: start; }
  .imp__facts dl { border-top: 1px solid var(--line); }
  .imp__row { display: grid; grid-template-columns: 1fr 1.3fr; gap: 1rem; padding: 1.1rem 0; border-bottom: 1px solid var(--line); }
  .imp__row dt { font-size: 0.82rem; font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase; color: var(--muted); }
  .imp__row dd { font-weight: 500; color: var(--pine-900); }

  .imp__contact { padding: 1.8rem; background: var(--pine-900); color: var(--on-dark); border-radius: var(--radius-lg); box-shadow: var(--shadow-md); }
  .imp__contact .kicker { color: var(--brass-400); }
  .imp__contact .kicker::before { background: var(--brass-400); }
  .imp__contact ul { list-style: none; padding: 0; margin-top: 1.2rem; display: flex; flex-direction: column; gap: 0.8rem; }
  .imp__contact li { display: flex; align-items: center; gap: 0.7rem; color: oklch(0.94 0.01 165 / 0.92); }
  .imp__contact svg { color: var(--brass-400); flex-shrink: 0; }
  .imp__contact a:hover { color: var(--brass-400); }
  .imp__haftung { margin-top: 1.6rem; padding: 1.3rem 1.5rem; background: var(--surface); border-radius: var(--radius); font-size: 0.9rem; color: var(--ink-soft); }
  .imp__side > .link-arrow { margin-top: 1.6rem; display: inline-flex; }

  @media (max-width: 820px) {
    .imp { grid-template-columns: 1fr; }
    .imp__row { grid-template-columns: 1fr; gap: 0.25rem; }
  }
</style>
